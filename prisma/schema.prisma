generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NEON_DATABASE_URL")
}

// ============================================================================
// USER MANAGEMENT
// ============================================================================

enum UserRole {
  ADMIN
  WRITER
  REVIEWER
  VIEWER
}

enum Industry {
  FINTECH
  INSURANCE
  HEALTHCARE
  LENDING
  SAAS
  INVESTMENT
  CRYPTO
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         UserRole  @default(WRITER)
  companyName  String?
  avatar       String?
  industry     Industry?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  teamMemberships TeamMember[]
  apiKeys         ApiKey[]
  accounts        Account[]
  sessions        Session[]
  content         Content[]
  communicationAnalyses CommunicationAnalysis[]
  transformPersonas   TransformPersona[]
  skillsRuns          SkillsRun[]

  @@index([email])
}

// ============================================================================
// SKILLS LAB — writing & speaking improvement (incl. exam-style modes)
// ============================================================================

model SkillsRun {
  id            String   @id @default(cuid())
  userId        String
  title         String
  mode          String
  examFramework String?
  taskPrompt    String?  @db.Text
  bodyText      String   @db.Text
  simPrompt     String?  @db.Text
  overallBand   Float?
  resultJson    Json?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// ============================================================================
// TRANSFORM (REWRITE) — user-defined personas for the Workspace Transform tab
// ============================================================================

model TransformPersona {
  id           String   @id @default(cuid())
  userId       String
  name         String
  instructions String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt(sort: Desc)])
}

// ============================================================================
// WRITING LAB — persisted analysis runs (dashboard / history)
// ============================================================================

model CommunicationAnalysis {
  id            String   @id @default(cuid())
  userId        String
  title         String
  source        String   // TEXT | VOICE | DICTATE
  kind          String   @default("full") // full | communication | run_all
  /// Draft copy at save time — shown in Workspace when reopening from history (no re-analysis).
  contentText   String?  @db.Text
  overallScore  Int?
  toneScore     Int?
  riskScore     Int?
  clarityScore  Int?
  aiProbability Int?
  riskLevel     String? // low | medium | high | critical (from compliance pass)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// NextAuth / Neon Auth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// TEAM MANAGEMENT
// ============================================================================

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  settings  Json     // team preferences
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members TeamMember[]
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

// ============================================================================
// API ACCESS
// ============================================================================

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  key        String    @unique
  lastUsedAt DateTime?
  expiresAt  DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
}

// ============================================================================
// ANALYTICS
// ============================================================================

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  teamId    String?
  eventType String
  eventData Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([teamId, createdAt])
  @@index([eventType, createdAt])
}

// ============================================================================
// CONTENT & COMPLIANCE
// ============================================================================

model Content {
  id               String    @id @default(cuid())
  userId           String
  title            String
  body             Json      // Tiptap JSON
  industry         Industry?
  targetKeyword    String?
  metaDescription  String?
  status           String    @default("DRAFT") // DRAFT | IN_REVIEW | APPROVED | PUBLISHED
  seoScore         Int?
  complianceScore  Int?
  riskLevel        String?   // low | medium | high | critical
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  flags ContentFlag[]

  @@index([userId])
  @@index([status])
  @@index([updatedAt(sort: Desc)])
}

model ContentFlag {
  id        String   @id @default(cuid())
  contentId String
  createdAt DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

model ContentBrief {
  id            String   @id @default(cuid())
  topic         String
  targetKeyword String?
  createdAt     DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

enum RuleType {
  PROHIBITED_CLAIM
  UNSUPPORTED_STAT
  MISSING_DISCLOSURE
  PERFORMANCE_CLAIM
  COMPARISON
  MEDICAL_ADVICE
  RISK_WARNING
}

enum Severity {
  CRITICAL
  WARNING
  INFO
}

model ComplianceRule {
  id                   String   @id @default(cuid())
  industry             Industry
  ruleName             String
  ruleType             RuleType
  severity             Severity
  pattern              String   @db.Text
  explanation          String   @db.Text
  regulationReference  String   @db.Text
  alternatives         String   @db.Text // JSON array
  isSystemRule         Boolean  @default(false)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())

  @@index([industry])
  @@index([isSystemRule])
}

// ============================================================================
// STANDEX SCORE — AI REPRESENTATION MANAGEMENT
// ============================================================================

model ReadinessScan {
  id             String   @id @default(cuid())
  dataset        String
  readinessScore Int      // 0-100
  tier           String   // excellent | moderate | high | critical
  breakdown      Json     // { schemaIntegrity, qualitySignals, dataFreshness, governanceCoverage }
  models         Json     // [{ model, text, flags: [{ claim, reason, severity }] }]
  flagCount      Int      @default(0)
  email          String?  // lead capture
  createdAt      DateTime @default(now())

  @@index([dataset])
  @@index([createdAt(sort: Desc)])
  @@index([tier])
}

// ============================================================================
// INTEGRATIONS
// ============================================================================

enum IntegrationType {
  HUBSPOT
  SLACK
  GOOGLE_ANALYTICS
  WEBHOOK
}

model Integration {
  id        String          @id @default(cuid())
  userId    String
  teamId    String?
  type      IntegrationType
  config    Json
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())

  @@index([userId])
  @@index([teamId])
}
