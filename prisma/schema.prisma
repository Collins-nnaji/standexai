generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NEON_DATABASE_URL")
}

// ============================================================================
// USER MANAGEMENT
// ============================================================================

enum UserRole {
  ADMIN
  WRITER
  REVIEWER
  VIEWER
  RESEARCHER // New networking role
  ENGINEER   // Implementation focus
  PRO        // Pro researcher
  LAB        // Enterprise scout/lab
}

enum Industry {
  FINTECH
  INSURANCE
  HEALTHCARE
  LENDING
  SAAS
  INVESTMENT
  CRYPTO
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  handle       String?   @unique
  name         String?
  passwordHash String
  role         UserRole  @default(WRITER)
  companyName  String?
  avatar       String?
  industry     Industry?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // StandexAI Network Profile Fields
  bio              String?   @db.Text
  institution      String?
  location         String?
  linkedinUrl      String?
  twitterUrl       String?
  githubUrl        String?
  websiteUrl       String?
  openToWork       Boolean   @default(false)
  verified         Boolean   @default(false)
  isVetted         Boolean   @default(false)
  vettedCategory   String?   // e.g. "Implementation", "Architecture"

  // Relations
  teamMemberships TeamMember[]
  apiKeys         ApiKey[]
  accounts        Account[]
  sessions        Session[]
  content         Content[]
  communicationAnalyses CommunicationAnalysis[]
  transformPersonas   TransformPersona[]
  skillsRuns          SkillsRun[]

  // StandexAI Network Relations
  workItems           WorkItem[]
  signalsReceived     ReputationSignal[] @relation("SignalsReceived")
  signalsGiven        ReputationSignal[] @relation("SignalsGiven")
  ranks               StandexRank[]
  collabMemberships   CollabMember[]
  briefsPosted        ResearchBrief[]    @relation("LabBriefs")
  briefInterests      BriefInterest[]
  followers           Follows[]          @relation("Followers")
  following           Follows[]          @relation("Following")
  labProfile          LabProfile?
  collabMessages      CollabMessage[]
  assessmentRuns      AssessmentRun[]

  @@index([email])
}

// ... remaining models ...

model ManagedProjectRequest {
  id            String   @id @default(cuid())
  companyName   String
  contactName   String
  email         String
  description   String   @db.Text
  budgetRange   String?
  timeline      String?
  status        String   @default("PENDING") // PENDING | IN_REVIEW | CONTACTED
  createdAt     DateTime @default(now())

  @@index([email])
}

// ============================================================================
// SKILLS LAB — writing & speaking improvement (incl. exam-style modes)
// ============================================================================

model SkillsRun {
  id            String   @id @default(cuid())
  userId        String
  title         String
  mode          String
  examFramework String?
  taskPrompt    String?  @db.Text
  bodyText      String   @db.Text
  simPrompt     String?  @db.Text
  overallBand   Float?
  resultJson    Json?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// ============================================================================
// TRANSFORM (REWRITE) — user-defined personas for the Workspace Transform tab
// ============================================================================

model TransformPersona {
  id           String   @id @default(cuid())
  userId       String
  name         String
  instructions String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt(sort: Desc)])
}

// ============================================================================
// WRITING LAB — persisted analysis runs (dashboard / history)
// ============================================================================

model CommunicationAnalysis {
  id            String   @id @default(cuid())
  userId        String
  title         String
  source        String   // TEXT | VOICE | DICTATE
  kind          String   @default("full") // full | communication | run_all
  /// Draft copy at save time — shown in Workspace when reopening from history (no re-analysis).
  contentText   String?  @db.Text
  overallScore  Int?
  toneScore     Int?
  riskScore     Int?
  clarityScore  Int?
  aiProbability Int?
  riskLevel     String? // low | medium | high | critical (from compliance pass)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// NextAuth / Neon Auth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// TEAM MANAGEMENT
// ============================================================================

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  settings  Json     // team preferences
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members TeamMember[]
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

// ============================================================================
// API ACCESS
// ============================================================================

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  key        String    @unique
  lastUsedAt DateTime?
  expiresAt  DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
}

// ============================================================================
// ANALYTICS
// ============================================================================

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  teamId    String?
  eventType String
  eventData Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([teamId, createdAt])
  @@index([eventType, createdAt])
}

// ============================================================================
// CONTENT & COMPLIANCE
// ============================================================================

model Content {
  id               String    @id @default(cuid())
  userId           String
  title            String
  body             Json      // Tiptap JSON
  industry         Industry?
  targetKeyword    String?
  metaDescription  String?
  status           String    @default("DRAFT") // DRAFT | IN_REVIEW | APPROVED | PUBLISHED
  seoScore         Int?
  complianceScore  Int?
  riskLevel        String?   // low | medium | high | critical
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  flags ContentFlag[]

  @@index([userId])
  @@index([status])
  @@index([updatedAt(sort: Desc)])
}

model ContentFlag {
  id        String   @id @default(cuid())
  contentId String
  createdAt DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

model ContentBrief {
  id            String   @id @default(cuid())
  topic         String
  targetKeyword String?
  createdAt     DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

enum RuleType {
  PROHIBITED_CLAIM
  UNSUPPORTED_STAT
  MISSING_DISCLOSURE
  PERFORMANCE_CLAIM
  COMPARISON
  MEDICAL_ADVICE
  RISK_WARNING
}

enum Severity {
  CRITICAL
  WARNING
  INFO
}

model ComplianceRule {
  id                   String   @id @default(cuid())
  industry             Industry
  ruleName             String
  ruleType             RuleType
  severity             Severity
  pattern              String   @db.Text
  explanation          String   @db.Text
  regulationReference  String   @db.Text
  alternatives         String   @db.Text // JSON array
  isSystemRule         Boolean  @default(false)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())

  @@index([industry])
  @@index([isSystemRule])
}

// ============================================================================
// STANDEX SCORE — AI REPRESENTATION MANAGEMENT
// ============================================================================

model ReadinessScan {
  id             String   @id @default(cuid())
  dataset        String
  readinessScore Int      // 0-100
  tier           String   // excellent | moderate | high | critical
  breakdown      Json     // { schemaIntegrity, qualitySignals, dataFreshness, governanceCoverage }
  models         Json     // [{ model, text, flags: [{ claim, reason, severity }] }]
  flagCount      Int      @default(0)
  email          String?  // lead capture
  createdAt      DateTime @default(now())

  @@index([dataset])
  @@index([createdAt(sort: Desc)])
  @@index([tier])
}

// ============================================================================
// INTEGRATIONS
// ============================================================================

enum IntegrationType {
  HUBSPOT
  SLACK
  GOOGLE_ANALYTICS
  WEBHOOK
}

model Integration {
  id        String          @id @default(cuid())
  userId    String
  teamId    String?
  type      IntegrationType
  config    Json
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())

  @@index([userId])
  @@index([teamId])
}

// ============================================================================
// STANDEXAI: PROFESSIONAL NETWORK
// ============================================================================

model WorkItem {
  id              String   @id @default(cuid())
  userId          String
  type            String   // paper, model, dataset, experiment, collab_experiment
  title           String
  abstract        String   @db.Text
  impactSummary   String   @db.Text
  problemSolved   String   @db.Text
  improvesOn      String   @db.Text
  tags            String[]
  externalUrl     String?
  fileUrl         String?  // Azure Blob Storage link
  views           Int      @default(0)
  createdAt       DateTime @default(now())

  // Co-authorship — set when published from a Collab Room
  collaborationId  String?
  coAuthors        String[] // array of User IDs for co-published work

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reputationSignals ReputationSignal[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([type])
}

model ReputationSignal {
  id           String   @id @default(cuid())
  userId       String   // The user receiving the signal
  signalType   String   // reproduction, citation, collab, review, lab_view
  workItemId   String?  // Optional relation to a work item
  fromUserId   String?  // The user giving the signal
  value        Int      // Points for this signal
  createdAt    DateTime @default(now())

  user         User      @relation("SignalsReceived", fields: [userId], references: [id], onDelete: Cascade)
  fromUser     User?     @relation("SignalsGiven", fields: [fromUserId], references: [id], onDelete: SetNull)
  workItem     WorkItem? @relation(fields: [workItemId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
}

model StandexRank {
  id           String   @id @default(cuid()) // Usually 1:1 with User
  userId       String   @unique
  domain       String   // ranking happens per domain
  score        Int      @default(0)
  rankPosition Int?     // updated via chron
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain])
  @@index([domain, rankPosition(sort: Asc)])
}

model Collaboration {
  id                   String   @id @default(cuid())
  title                String
  description          String   @db.Text
  visibility           String   @default("private") // public | private
  status               String   @default("active")  // active | completed
  createdAt            DateTime @default(now())

  // Loop traceability — links back to the source Brief and forward to output
  briefId              String?  // optional link to source ResearchBrief
  publishedWorkItemId  String?  // set when collab is published
  canvasContent        String?  @db.Text

  members     CollabMember[]
  messages    CollabMessage[]
  brief       ResearchBrief?   @relation("CollabSource", fields: [briefId], references: [id], onDelete: SetNull)
}

model CollabMember {
  id            String   @id @default(cuid())
  collabId      String
  userId        String
  role          String   @default("contributor")

  collaboration Collaboration @relation(fields: [collabId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([collabId, userId])
}

model CollabMessage {
  id              String   @id @default(cuid())
  collabId        String
  userId          String
  content         String   @db.Text
  createdAt       DateTime @default(now())

  collaboration   Collaboration @relation(fields: [collabId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([collabId, createdAt(sort: Asc)])
}

model ResearchBrief {
  id          String   @id @default(cuid())
  companyId   String   // lab User id
  title       String
  description String   @db.Text
  lookingFor  String   @db.Text
  domain      String[]
  active      Boolean  @default(true)
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  company     User            @relation("LabBriefs", fields: [companyId], references: [id], onDelete: Cascade)
  interests   BriefInterest[]
  collabs     Collaboration[] @relation("CollabSource")

  @@index([companyId, createdAt(sort: Desc)])
}

model BriefInterest {
  id            String   @id @default(cuid())
  briefId       String
  userId        String
  message       String?  @db.Text
  createdAt     DateTime @default(now())

  brief         ResearchBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([briefId, userId])
}

model Follows {
  followerId  String
  followingId String

  follower    User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model LabProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  companyName      String
  logo             String?
  verified         Boolean  @default(false)
  subscriptionTier String   @default("base")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================================
// LEARNING PLATFORM
// ============================================================================

enum CourseTrack {
  STARTER
  PROFESSIONAL
  BUILDER
  CORPORATE
  PRIME_BESPOKE
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

model Course {
  id            String      @id @default(cuid())
  title         String
  description   String      @db.Text
  track         CourseTrack
  level         CourseLevel @default(BEGINNER)
  priceUSD      Float?      
  priceGBP      Float?
  priceNGN      Float?
  modulesCount  Int         @default(0)
  duration      String?     
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  modules       Module[]

  @@index([track])
}

model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?  @db.Text
  order       Int
  content     Json?    
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

// ============================================================================
// AI ASSESSMENTS
// ============================================================================

model AssessmentRun {
  id              String   @id @default(cuid())
  userId          String
  score           Int
  totalQuestions  Int
  tier            String
  history         Json     // Stores array of questions + answers
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}
