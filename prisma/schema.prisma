generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NEON_DATABASE_URL")
}

// ============================================================================
// USER MANAGEMENT
// ============================================================================

enum UserRole {
  ADMIN
  WRITER
  REVIEWER
  VIEWER
}

enum Industry {
  FINTECH
  INSURANCE
  HEALTHCARE
  LENDING
  SAAS
  INVESTMENT
  CRYPTO
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          UserRole  @default(WRITER)
  industry      Industry?
  companyName   String?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  content          Content[]
  contentVersions  ContentVersion[]
  approvals        Approval[]
  comments         Comment[]
  briefs           ContentBrief[]
  teamMemberships  TeamMember[]
  apiKeys          ApiKey[]
  accounts         Account[]
  sessions         Session[]

  @@index([email])
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// TEAM MANAGEMENT (v1.5)
// ============================================================================

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  industry  Industry
  settings  Json     // team preferences, compliance frameworks
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  TeamMember[]
  content  Content[]
  rules    ComplianceRule[]
  templates ContentTemplate[]
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

// ============================================================================
// CONTENT MANAGEMENT
// ============================================================================

enum ContentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Content {
  id              String        @id @default(cuid())
  userId          String
  teamId          String?
  title           String
  body            Json          // Tiptap JSON document
  status          ContentStatus @default(DRAFT)
  complianceScore Int?          // 0-100
  seoScore        Int?          // 0-100
  riskLevel       RiskLevel?
  industry        Industry
  targetKeyword   String?
  metaDescription String?
  slug            String?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  team        Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  flags       ComplianceFlag[]
  versions    ContentVersion[]
  approvals   Approval[]
  comments    Comment[]
  seoAnalysis SeoAnalysis[]

  @@index([userId])
  @@index([teamId])
  @@index([status])
  @@index([riskLevel])
  @@index([updatedAt(sort: Desc)])
}

// ============================================================================
// VERSION CONTROL & AUDIT TRAIL
// ============================================================================

model ContentVersion {
  id              String     @id @default(cuid())
  contentId       String
  version         Int
  body            Json
  complianceScore Int?
  seoScore        Int?
  riskLevel       RiskLevel?
  userId          String
  changeNote      String?
  createdAt       DateTime   @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([contentId, version])
  @@index([contentId, createdAt(sort: Desc)])
}

// ============================================================================
// COMPLIANCE SYSTEM
// ============================================================================

enum RuleType {
  PROHIBITED_CLAIM
  MISSING_DISCLOSURE
  UNSUPPORTED_STAT
  MEDICAL_ADVICE
  GUARANTEE_LANGUAGE
  RISK_WARNING
  LICENSING_INFO
  PERFORMANCE_CLAIM
  TESTIMONIAL
  COMPARISON
}

enum Severity {
  CRITICAL
  WARNING
  INFO
}

model ComplianceRule {
  id                  String   @id @default(cuid())
  teamId              String?  // null = system rule, set = custom team rule
  industry            Industry
  ruleName            String
  ruleType            RuleType
  severity            Severity
  pattern             String   // regex pattern or keyword
  explanation         String   @db.Text
  regulationReference String?  @db.Text
  alternatives        Json     // array of compliant alternatives
  active              Boolean  @default(true)
  isSystemRule        Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  team  Team?            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  flags ComplianceFlag[]

  @@index([industry, active])
  @@index([teamId])
}

enum FlagStatus {
  ACTIVE
  FIXED
  DISMISSED
  ACKNOWLEDGED
}

model ComplianceFlag {
  id                  String     @id @default(cuid())
  contentId           String
  ruleId              String
  flaggedText         String     @db.Text
  severity            Severity
  explanation         String     @db.Text
  regulationReference String?    @db.Text
  alternatives        Json
  status              FlagStatus @default(ACTIVE)
  lineNumber          Int?
  charPosition        Int?
  dismissedBy         String?
  dismissedAt         DateTime?
  fixedAt             DateTime?
  createdAt           DateTime   @default(now())

  content Content        @relation(fields: [contentId], references: [id], onDelete: Cascade)
  rule    ComplianceRule @relation(fields: [ruleId], references: [id])

  @@index([contentId, status])
  @@index([severity])
}

// ============================================================================
// SEO ANALYSIS
// ============================================================================

model SeoAnalysis {
  id                String   @id @default(cuid())
  contentId         String
  keyword           String?
  keywordDensity    Float?
  readabilityScore  Int?
  wordCount         Int
  structureAnalysis Json
  suggestions       Json
  metaSuggestions   Json
  createdAt         DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

// ============================================================================
// CONTENT BRIEF GENERATOR
// ============================================================================

model ContentBrief {
  id                   String   @id @default(cuid())
  userId               String
  teamId               String?
  topic                String
  industry             Industry
  targetKeyword        String?
  competitorUrls       Json     // array of URLs
  competitiveAnalysis  Json     // analysis results
  recommendedOutline   Json
  complianceGuidelines Json
  targetMetrics        Json
  createdAt            DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

// ============================================================================
// APPROVAL WORKFLOW
// ============================================================================

enum ApprovalStatus {
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

model Approval {
  id         String         @id @default(cuid())
  contentId  String
  reviewerId String
  status     ApprovalStatus
  comments   String?        @db.Text
  version    Int?
  createdAt  DateTime       @default(now())

  content  Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  reviewer User    @relation(fields: [reviewerId], references: [id])

  @@index([contentId])
  @@index([reviewerId])
}

// ============================================================================
// COMMENTS & COLLABORATION (v1.5)
// ============================================================================

model Comment {
  id         String   @id @default(cuid())
  contentId  String
  userId     String
  text       String   @db.Text
  lineNumber Int?
  resolved   Boolean  @default(false)
  parentId   String?  // for threaded comments
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  content Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id])
  parent  Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentThread")

  @@index([contentId])
  @@index([userId])
}

// ============================================================================
// API ACCESS (v2.0)
// ============================================================================

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  key        String    @unique
  lastUsedAt DateTime?
  expiresAt  DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
}

// ============================================================================
// ANALYTICS & REPORTING
// ============================================================================

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  teamId    String?
  eventType String
  eventData Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([teamId, createdAt])
  @@index([eventType, createdAt])
}

// ============================================================================
// CONTENT TEMPLATES (v1.5)
// ============================================================================

model ContentTemplate {
  id          String   @id @default(cuid())
  teamId      String?
  name        String
  description String?  @db.Text
  industry    Industry
  body        Json     // Tiptap JSON template
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())

  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([industry])
  @@index([teamId])
}

// ============================================================================
// INTEGRATION SETTINGS (v2.0)
// ============================================================================

enum IntegrationType {
  WORDPRESS
  HUBSPOT
  MARKETO
  SLACK
  GOOGLE_DOCS
  GOOGLE_ANALYTICS
}

model Integration {
  id        String          @id @default(cuid())
  userId    String
  teamId    String?
  type      IntegrationType
  config    Json            // integration-specific settings
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())

  @@index([userId])
  @@index([teamId])
}
